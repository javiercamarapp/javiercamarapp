# ===========================================
# HatoAI — Variables de Entorno
# ===========================================
# Copia este archivo como .env.local y llena los valores

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Supabase Service Role (solo server-side, NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Anthropic Claude API (para AI Insights)
ANTHROPIC_API_KEY=sk-ant-tu-key-aqui

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp Business API (Meta)
WHATSAPP_VERIFY_TOKEN=hatoai_webhook_2026
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# OpenAI (para Whisper transcripción de voz)
OPENAI_API_KEY=sk-your-openai-key

# Google Vision (para OCR de aretes SINIIGA) — opcional
GOOGLE_VISION_API_KEY=your_google_vision_key

# WhatsApp App Secret (para verificar firma de webhooks)
WHATSAPP_APP_SECRET=your_app_secret
